# Binance USD-M Futures Demo-only configuration.
# Execution must remain disabled until all Prompt 1 safety gates pass.

POSTGRES_DB=binance_scalping_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
BACKEND_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/binance_scalping_bot
BACKEND_APP_ENV=development

# Safety defaults
BACKEND_EXECUTION_ENABLED=false
BACKEND_DEMO_TRADING_MODE=true
BACKEND_EMERGENCY_STOP=false

# Binance USD-M Futures Demo credentials only.
# Never place Binance production or real-money credentials here.
BACKEND_BINANCE_DEMO_API_KEY=
BACKEND_BINANCE_DEMO_API_SECRET=

# Only the allowlisted HTTPS Binance Futures Demo host is supported.
BACKEND_BINANCE_TRADING_BASE_URL=https://demo-fapi.binance.com
BACKEND_BINANCE_MARKET_DATA_BASE_URL=https://demo-fapi.binance.com

BACKEND_MARKET_DATA_COLLECTION_ENABLED=false
FRONTEND_API_BASE_URL=http://localhost:8000

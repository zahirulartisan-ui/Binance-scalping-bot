# ==============================================================================
# Root Environment Configuration for Binance USD-M Futures Demo
# Strictly Binance USD-M Futures Demo-only. No Spot, no production, no real-money.
# ==============================================================================

POSTGRES_DB=binance_scalping_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
BACKEND_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/binance_scalping_bot
BACKEND_APP_ENV=development

# Dedicated Futures Demo credentials (read-only from env)
BACKEND_BINANCE_FUTURES_DEMO_API_KEY=
BACKEND_BINANCE_FUTURES_DEMO_API_SECRET=
BACKEND_BINANCE_RECV_WINDOW=5000

# Canonical base URL and market data (HTTPS and testnet.binancefuture.com only)
BACKEND_BINANCE_FUTURES_DEMO_BASE_URL=https://testnet.binancefuture.com
BACKEND_BINANCE_FUTURES_DEMO_MARKET_DATA_URL=https://testnet.binancefuture.com

# Safety guards (execution defaults OFF)
BACKEND_EXECUTION_ENABLED=false
BACKEND_DEMO_TRADING_MODE=false
BACKEND_EMERGENCY_STOP=false
BACKEND_MARKET_DATA_COLLECTION_ENABLED=false

FRONTEND_API_BASE_URL=http://localhost:8000

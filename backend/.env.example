APP_NAME=Binance Scalping Bot
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/binance_scalping_bot
ALLOWED_ORIGINS=http://localhost:5173
BINANCE_DEMO_API_KEY=
BINANCE_DEMO_API_SECRET=
EXECUTION_ENABLED=false
DEMO_TRADING_MODE=true
SCANNER_INTERVAL_SECONDS=30
RISK_PER_TRADE=0.01
MAXIMUM_OPEN_TRADES=3
DAILY_LOSS_LIMIT=0.03
EMERGENCY_STOP=false
BINANCE_MARKET_DATA_BASE_URL=https://api.binance.com
BINANCE_MARKET_DATA_TIMEOUT_SECONDS=5
BINANCE_MARKET_DATA_MAX_RETRIES=2
BINANCE_MARKET_DATA_BACKOFF_SECONDS=0.25
MARKET_DATA_COLLECTION_ENABLED=false
MARKET_DATA_SYMBOL_REFRESH_SECONDS=3600
MARKET_DATA_CYCLE_INTERVAL_SECONDS=60
MARKET_DATA_SYMBOLS=BTCUSDT,ETHUSDT
REGIME_MINIMUM_CANDLES=60
REGIME_TREND_STRENGTH_THRESHOLD=20
REGIME_ATR_PERCENT_MIN=0.02
REGIME_ATR_PERCENT_MAX=2.5
REGIME_REALIZED_VOLATILITY_MAX=3
REGIME_ABNORMAL_CANDLE_PERCENT=5
REGIME_VOLUME_SPIKE_MULTIPLIER=4
REGIME_MAX_SPREAD_BPS=15
REGIME_EMA_SLOPE_THRESHOLD=0.001
REGIME_RANGE_COMPRESSION_THRESHOLD=1
REGIME_BTC_BLOCK_VOLATILITY_PERCENT=3
REGIME_CACHE_SECONDS=30
